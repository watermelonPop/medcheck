<div class="innerScheduleContent">
        <p class="medTxt fonted"><%= Date.parse(@date).strftime("%A, %B %e") %></p>
        <div class="dayScrollDiv">
                <% @taken_by_date.each do |day| %>
                        <div class="eachSchedDiv">
                                        <div class="medicationIconDiv">
                                                <svg class="medicationIcon" viewBox="0 0 100 100" style="fill: <%= day[:medication_schedule].medication.color %>;">
                                                        <%= raw(day[:medication_schedule].medication.icon)%>
                                                </svg>
                                        </div>
                                        <div class="innerTxtDiv">
                                                <p class="medTxt"><%= day[:medication_schedule].medication.amount_taken %> <%= day[:medication_schedule].medication.name %> <%= day[:medication_schedule].medication.dose_amount %><%= day[:medication_schedule].medication.dose_unit %> @ <%= day[:medication_schedule].time.strftime("%l:%M %p") %></p>
                                        </div>
                                        <% if day[:taken].to_s == "true" %>
                                                <div class="takeMedDiv">
                                                        <svg class="takeMedIcon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                                <g data-name="Layer 2">
                                                                <g data-name="checkmark-circle-2">
                                                                <rect width="24" height="24" opacity="0"/>
                                                                <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/>
                                                                <path d="M14.7 8.39l-3.78 5-1.63-2.11a1 1 0 0 0-1.58 1.23l2.43 3.11a1 1 0 0 0 .79.38 1 1 0 0 0 .79-.39l4.57-6a1 1 0 1 0-1.6-1.22z"/>
                                                                </g>
                                                                </g>
                                                        </svg>
                                                </div>
                                        <% else %>
                                                <div class="takenMedDiv">
                                                        <svg class="takenMedIcon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                                <path d="M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                        </svg>
                                                </div>
                                        <% end %>
                        </div>
                <% end %>
                <% if Date.parse(@date) > Date.today %>
                        <% get_all_medication_day_schedules(day_of_week: Date.parse(@date).strftime("%A"), date_needed: @date).each do |event| %>
                                <div class="eachSchedDiv">
                                        <div class="medicationIconDiv">
                                                <svg class="medicationIcon" viewBox="0 0 100 100" style="fill: <%= event.medication_schedule.medication.color %>;">
                                                        <%= raw(event.medication_schedule.medication.icon)%>
                                                </svg>
                                        </div>
                                        <div class="innerTxtDiv">
                                                <p class="medTxt"><%= event.medication_schedule.medication.amount_taken %> <%= event.medication_schedule.medication.name %> <%= event.medication_schedule.medication.dose_amount %><%= event.medication_schedule.medication.dose_unit %> @ <%= event.medication_schedule.time.strftime("%l:%M %p") %></p>
                                        </div>
                                        <% if event.taken.to_s == "true" %>
                                                <div class="takeMedDiv">
                                                        <svg class="takeMedIcon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                                <g data-name="Layer 2">
                                                                <g data-name="checkmark-circle-2">
                                                                <rect width="24" height="24" opacity="0"/>
                                                                <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/>
                                                                <path d="M14.7 8.39l-3.78 5-1.63-2.11a1 1 0 0 0-1.58 1.23l2.43 3.11a1 1 0 0 0 .79.38 1 1 0 0 0 .79-.39l4.57-6a1 1 0 1 0-1.6-1.22z"/>
                                                                </g>
                                                                </g>
                                                        </svg>
                                                </div>
                                        <% else %>
                                                <div class="takenMedDiv">
                                                        <svg class="takenMedIcon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                                <path d="M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                                        </svg>
                                                </div>
                                        <% end %>
                                </div>
                        <% end %>
                <% end %>
        </div>
</div>