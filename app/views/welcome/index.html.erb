<%= stylesheet_link_tag "login", "data-turbo-track": "reload" %>
<head>
    <script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer></script>
    <script>
    window.OneSignalDeferred = window.OneSignalDeferred || [];
    OneSignalDeferred.push(function(OneSignal) {
        OneSignal.init({
        appId: "90311568-0504-428b-9c92-0b1dda7bea46",
        });
    });
    </script>
</head>
<div class="container">
    <div class="appTitleDiv">
        <p class="appTitle">medcheck</p>
    </div>

    <div class="logoDiv">
        <%= image_tag "/images/app-icon.png", alt: "Image Description", class: "logo" %>
    </div>

    <div class="loginBtnDiv">
        <%= button_to "Login with Google", "/auth/google_oauth2", data: {turbo: "false"}, class: "login-btn" %>
    </div>
</div>